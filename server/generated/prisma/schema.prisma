generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Faculty {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  username      String         @unique @db.VarChar(255)
  password      String         @db.VarChar(255)
  students      Student[]
  announcements Announcement[]

  @@map("faculties")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  facultyId Int
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model Department {
  departmentId   Int       @id @default(autoincrement())
  acronym        String    @db.VarChar(15)
  departmentName String    @db.VarChar(255)
  students       Student[]

  @@map("departments")
}

model Student {
  id            Int          @id @default(autoincrement())
  rfidTag       String?      @unique @db.VarChar(50)
  firstName     String       @db.VarChar(50)
  lastName      String       @db.VarChar(50)
  middleInitial String?      @db.VarChar(1)
  birthDate     DateTime?    @db.Date
  address       String?      @db.VarChar(255)
  guardianName  String?      @db.VarChar(100)
  guardianPhone String?      @db.VarChar(20)
  departmentId  Int?
  year          Int          @db.TinyInt
  photo         String?      @db.VarChar(255)
  facultyId     Int?
  department    Department?  @relation(fields: [departmentId], references: [departmentId], onDelete: SetNull)
  faculty       Faculty?     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  attendances   Attendance[]

  @@map("students")
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  type      String   @db.VarChar(3)
  timestamp DateTime @db.DateTime(0)
  date      DateTime @db.Date
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("attendances")
}
